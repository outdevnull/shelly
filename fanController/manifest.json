{
  "kvsDefaultsVersion": "3",
  "config": {
    "BLE.SetConfig": {
      "config": {
        "enable": false
      }
    }
  },
  "kvsConfig": {
    "mqtt.enable":       { "method": "Mqtt.SetConfig", "config": { "enable": true } },
    "mqtt.server":       { "method": "Mqtt.SetConfig", "config": { "server": "192.168.x.x:1883" } },
    "mqtt.client_id":    { "method": "Mqtt.SetConfig", "config": { "client_id": "bathroom-fan" } },
    "mqtt.topic_prefix": { "method": "Mqtt.SetConfig", "config": { "topic_prefix": "shelly/bathroom-fan" } },
    "device.name":       { "method": "Sys.SetConfig",  "config": { "device": { "name": "Bathroom Fan Controller" } } },
    "device.tz":         { "method": "Sys.SetConfig",  "config": { "location": { "tz": "Australia/Sydney" } } }
  },
  "kvsDefaults": {
    "wd.health_interval":            300,
    "wd.rpc_delay":                  200,
    "wd.tz_offset":                  36000,
    "fan.room_name":                 "Bathroom",
    "fan.shower_spike":              0.60,
    "fan.abs_surplus_threshold":     2.0,
    "fan.abs_surplus_delta":         0.6,
    "fan.spread_margin":             0.5,
    "fan.dewpoint_spike":            1.0,
    "fan.boost_cycles":              5,
    "fan.min_runtime":               900,
    "fan.quiet_hours_start":         11,
    "fan.quiet_hours_end":           18,
    "fan.quiet_hours_avg_override":  0.5,
    "fan.passive_surplus_threshold": 2.5,
    "fan.passive_drying_min":        1.25,
    "fan.passive_runtime":           600
  },
  "components": [
    { "type": "number", "id": 200, "name": "int_humidity" },
    { "type": "number", "id": 201, "name": "int_temperature" },
    { "type": "number", "id": 202, "name": "ext_humidity" },
    { "type": "number", "id": 203, "name": "ext_temperature" },
    { "type": "text",   "id": 200, "name": "moisture_trend" }
  ],
  "scripts": [
    { "id": 1, "name": "bootstrap",     "file": "bootstrap.js",   "version": "2.0.0", "autostart": false },
    { "id": 2, "name": "supervisor",    "file": "supervisor.js",   "version": "1.0.0", "autostart": true  },
    { "id": 3, "name": "updater",       "file": "updater.js",      "version": "1.0.0", "autostart": false },
    { "id": 4, "name": "kvs_restore",                                                   "autostart": false },
    { "id": 5, "name": "fancontroller", "file": "fancontroller.js","version": "1.0.7", "autostart": false }
  ]
}
